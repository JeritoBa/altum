<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Altum</title>
</head>
<body>
    <header>
        <nav>
            <ul>
                
                <li><a asp-controller="Property" asp-action="Index">Properties</a></li>

                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    @if (User.IsInRole("Owner")) {
                        <li><a asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
                    }
                    <li><a asp-controller="Favorite" asp-action="Index">Favorites</a></li>
                    <li><a asp-controller="Booking" asp-action="Index">Bookings</a></li>

                    <li>
                        <form asp-controller="Auth" asp-action="Logout" method="post" style="display:inline;">
                            <button type="submit" style="background:none; border:none; color:blue; text-decoration:underline; cursor:pointer;">Logout (@User.Identity.Name)</button>
                        </form>
                    </li>
                }
                else
                {
                    <li><a asp-controller="Auth" asp-action="Login">Login</a></li>
                    <li><a asp-controller="Auth" asp-action="Register">Register</a></li>
                }
            </ul>
        </nav>
    </header>
    
    <main role="main">
        @RenderBody()
    </main>

    <footer style="margin-top: 50px;">
        <p>&copy; 2026 - Altum App</p>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
