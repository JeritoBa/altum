@model IEnumerable<main.Models.Favorite>
@{
    ViewData["Title"] = "Favorites";
    var isGuest = User.IsInRole("Guest");
}

<h2>My Favorites</h2>

<form method="get" asp-action="Index">
    <div style="margin-bottom: 15px;">
        <input type="text" name="location" placeholder="Search by location..." value="@ViewBag.Location" />
        <input type="date" name="availableDate" value="@ViewBag.AvailableDate" />
        <input type="number" name="propertyId" placeholder="Property ID..." value="@ViewBag.PropertyId" />
        
        <button type="submit">Filter</button>
        <a asp-action="Index">Clear</a>
    </div>
</form>

<div style="display: flex; flex-wrap: wrap; gap: 20px;">
    @if (!Model.Any())
    {
        <p>No favorites found.</p>
    }
    
    @foreach(var fav in Model)
    {
        <div style="border: 1px solid #ccc; border-radius: 8px; padding: 15px; width: 300px; box-shadow: 2px 2px 5px rgba(0,0,0,0.1);">
            @if (!string.IsNullOrEmpty(fav.Property.MainImageUrl))
            {
                <img src="@fav.Property.MainImageUrl" alt="@fav.Property.Name" style="width: 100%; height: 200px; object-fit: cover; border-radius: 4px;" />
            }
            <h3 style="margin-top: 10px; margin-bottom: 5px;">@fav.Property.Name</h3>
            <p style="margin: 5px 0; color: #28a745; font-weight: bold;">$@fav.Property.PricePerNight / night</p>
            <p style="margin: 5px 0;"><strong>Location:</strong> @fav.Property.City, @fav.Property.Country</p>
            <p style="margin: 5px 0;"><strong>Bedrooms:</strong> @fav.Property.Bedrooms</p>
            <p style="margin: 5px 0;"><strong>Available:</strong> @(fav.Property.IsAvailable ? "Yes" : "No")</p>
            
            <div style="margin-top: 15px; padding-top: 10px; border-top: 1px solid #eee; display: flex; align-items: center; justify-content: space-between;">
                <div>
                    <a asp-controller="Property" asp-action="Details" asp-route-id="@fav.PropertyId">View Details</a>
                    
                    @if (isGuest && fav.Property.IsAvailable)
                    {
                        <span style="margin: 0 5px;">|</span>
                        <a asp-controller="Booking" asp-action="Create" asp-route-propertyId="@fav.PropertyId" style="color: green; font-weight: bold; text-decoration: none;">Book Now</a>
                    }
                </div>
                
                <dialog id="deleteModal_@fav.Id" style="border: none; border-radius: 8px; padding: 20px; box-shadow: 0 4px 6px rgba(0,0,0,0.1);">
                    <h3 style="margin-top:0;">Remove Favorite</h3>
                    <p>Are you sure you want to remove this property from favorites?</p>
                    <div style="margin-top: 20px; text-align: right;">
                        <button type="button" onclick="document.getElementById('deleteModal_@fav.Id').close()" style="padding:8px 12px; border-radius:4px; cursor:pointer; background:#eee; border:1px solid #ccc; margin-right: 10px;">Cancel</button>
                        <form asp-action="Delete" asp-route-id="@fav.Id" method="post" style="display:inline;">
                            <button type="submit" style="background:red; color:white; border:none; padding:8px 12px; border-radius:4px; cursor:pointer;">Yes, Remove</button>
                        </form>
                    </div>
                </dialog>
                <button type="button" onclick="document.getElementById('deleteModal_@fav.Id').showModal()" style="background:none; border:none; color:red; text-decoration:underline; cursor:pointer; padding:0;">Remove</button>
            </div>
        </div>
    }
</div>
