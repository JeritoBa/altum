@model main.Models.Property
@{
    ViewData["Title"] = Model.Name;
}

<h2>@Model.Name</h2>

<div style="display: flex; gap: 20px; flex-wrap: wrap;">
    @if (!string.IsNullOrEmpty(Model.MainImageUrl))
    {
        <div style="flex: 1; min-width: 300px;">
            <img src="@Model.MainImageUrl" alt="@Model.Name" style="max-width: 100%; border-radius: 8px; box-shadow: 2px 2px 8px rgba(0,0,0,0.2);" />
        </div>
    }
    
    <div style="flex: 1; min-width: 300px;">
        <h3>Description</h3>
        <p style="white-space: pre-wrap;">@Model.Description</p>
        
        <h3>Property Details</h3>
        <ul>
            <li><strong>Price per Night:</strong> <span style="color: #28a745; font-weight: bold;">$@Model.PricePerNight</span></li>
            <li><strong>Address:</strong> @Model.Address, @Model.City, @Model.Country</li>
            <li><strong>Max Guests:</strong> @Model.MaxGuests</li>
            <li><strong>Bedrooms:</strong> @Model.Bedrooms</li>
            <li><strong>Bathrooms:</strong> @Model.Bathrooms</li>
            <li><strong>Status:</strong> @(Model.IsAvailable ? "Available to book" : "Not available")</li>
        </ul>
        
        <div style="margin-top: 20px; padding: 15px; background: #f9f9f9; border-radius: 8px; border: 1px solid #ddd;">
            <p><em>Favorite option will be placed here soon</em></p>

            @if (User.IsInRole("Guest") && Model.IsAvailable)
            {
                <a asp-controller="Booking" asp-action="Create" asp-route-propertyId="@Model.Id" style="display:inline-block; background-color: #007bff; color: white; padding: 10px 15px; text-decoration: none; border-radius: 4px;">Book Now</a>
            }
            else if (!Model.IsAvailable)
            {
                <p style="color: red; margin: 0;">This property is not available for booking right now.</p>
            }
            else if (User.IsInRole("Owner"))
            {
                <p style="color: #666; margin: 0;">Owners cannot book properties.</p>
            }
        </div>
    </div>
</div>

<div style="margin-top: 20px;">
    <a asp-action="Index" style="text-decoration: none; color: blue;">← Back to Properties list</a>
</div>
