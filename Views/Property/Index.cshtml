@model IEnumerable<main.Models.Property>
@using Microsoft.AspNetCore.Identity
@inject UserManager<main.Models.User> UserManager
@inject main.Services.Interfaces.IFavoriteService FavoriteService
@{
    ViewData["Title"] = "Properties";
    var isOwner = User.IsInRole("Owner");
    var user = await UserManager.GetUserAsync(User);
    
    HashSet<int> favoritePropertyIds = new HashSet<int>();
    if (user != null)
    {
        var favResponse = await FavoriteService.GetFavoritesAsync(user.Id);
        if (favResponse.Success && favResponse.Data != null)
        {
            favoritePropertyIds = favResponse.Data.Select(f => f.PropertyId).ToHashSet();
        }
    }
}

<h2>Properties</h2>

<form method="get" asp-action="Index">
    <div style="margin-bottom: 10px;">
        <input type="text" name="name" placeholder="Search by name" value="@ViewBag.Name" />
        <input type="text" name="location" placeholder="Search by city/country" value="@ViewBag.Location" />
        <input type="date" name="availableDate" value="@ViewBag.AvailableDate" />
        
        @if (isOwner)
        {
            <label>
                <input type="checkbox" name="myPropertiesOnly" value="true" @(ViewBag.MyPropertiesOnly == true ? "checked" : "") /> My Properties
            </label>
        }
        
        <button type="submit">Search</button>
        <a asp-action="Index">Clear</a>
    </div>
</form>

@if (isOwner)
{
    <div style="margin-bottom: 15px;">
        <a asp-action="Create">Create New Property</a>
    </div>
}

<div style="display: flex; flex-wrap: wrap; gap: 20px;">
    @foreach(var prop in Model)
    {
        <div style="border: 1px solid #ccc; border-radius: 8px; padding: 15px; width: 300px; box-shadow: 2px 2px 5px rgba(0,0,0,0.1);">
            @if (!string.IsNullOrEmpty(prop.MainImageUrl))
            {
                <img src="@prop.MainImageUrl" alt="@prop.Name" style="width: 100%; height: 200px; object-fit: cover; border-radius: 4px;" />
            }
            <h3 style="margin-top: 10px; margin-bottom: 5px;">@prop.Name</h3>
            <p style="margin: 5px 0; color: #28a745; font-weight: bold;">$@prop.PricePerNight / night</p>
            <p style="margin: 5px 0;"><strong>Location:</strong> @prop.City, @prop.Country</p>
            <p style="margin: 5px 0;"><strong>Max Guests:</strong> @prop.MaxGuests</p>
            <p style="margin: 5px 0;"><strong>Bedrooms:</strong> @prop.Bedrooms</p>
            <p style="margin: 5px 0;"><strong>Bathrooms:</strong> @prop.Bathrooms</p>
            <p style="margin: 5px 0;"><strong>Available:</strong> @(prop.IsAvailable ? "Yes" : "No")</p>
            
            <div style="margin-top: 15px; padding-top: 10px; border-top: 1px solid #eee;">
                @if (favoritePropertyIds.Contains(prop.Id))
                {
                    <span style="color:#ff007f; font-weight:bold; margin-right: 5px;">❤ In favorites</span>
                }
                else
                {
                    <form asp-controller="Favorite" asp-action="Add" asp-route-propertyId="@prop.Id" method="post" style="display:inline; margin-right: 5px;">
                        <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                        <button type="submit" style="background:none; border:none; color:#ff007f; text-decoration:none; cursor:pointer; padding:0; font-weight:bold;">❤ Add</button>
                    </form>
                }
                <a asp-action="Details" asp-route-id="@prop.Id">View Details</a>
                
                @if (User.IsInRole("Guest") && prop.IsAvailable)
                {
                    <span style="margin: 0 5px;">|</span>
                    <a asp-controller="Booking" asp-action="Create" asp-route-propertyId="@prop.Id" style="color: green; font-weight: bold; text-decoration: none;">Book Now</a>
                }
                
                @if (isOwner && prop.OwnerId == user?.Id)
                {
                    <span style="margin: 0 5px;">|</span>
                    <a asp-action="Edit" asp-route-id="@prop.Id" style="color: orange;">Edit</a>
                    <span style="margin: 0 5px;">|</span>
                    <form asp-action="Delete" asp-route-id="@prop.Id" method="post" style="display:inline;">
                        <button type="submit" onclick="return confirm('Are you sure you want to delete this property?');" style="background:none; border:none; color:red; text-decoration:underline; cursor:pointer; padding:0;">Delete</button>
                    </form>
                }
            </div>
        </div>
    }
</div>