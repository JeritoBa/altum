@model IEnumerable<main.Models.Property>
@using Microsoft.AspNetCore.Identity
@inject UserManager<main.Models.User> UserManager
@inject main.Services.Interfaces.IFavoriteService FavoriteService
@{
    ViewData["Title"] = "Propiedades";
    var isOwner = User.IsInRole("Owner");
    var user = await UserManager.GetUserAsync(User);
    
    HashSet<int> favoritePropertyIds = new HashSet<int>();
    if (user != null)
    {
        var favResponse = await FavoriteService.GetFavoritesAsync(user.Id);
        if (favResponse.Success && favResponse.Data != null)
        {
            favoritePropertyIds = favResponse.Data.Select(f => f.PropertyId).ToHashSet();
        }
    }
}

<!-- Header Section -->
<div class="mb-12">
    <h1 class="font-headline-lg text-headline-lg text-primary mb-4">Propiedades Exclusivas</h1>
    <p class="font-body-lg text-body-lg text-on-surface-variant">Descubre nuestro catálogo de propiedades de lujo</p>
</div>

<!-- Search & Filter Form -->
<div class="bg-surface-container-lowest rounded-xl border border-outline-variant p-8 mb-12">
    <form method="get" asp-action="Index" class="space-y-6">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
            <!-- Search by Name -->
            <div>
                <label class="block font-label-sm text-label-sm text-on-surface-variant mb-2 uppercase tracking-wider">Nombre de Propiedad</label>
                <input type="text" 
                       name="name" 
                       placeholder="Villa, Casa, Apartamento..." 
                       value="@ViewBag.Name"
                       class="form-input w-full p-4 border border-outline-variant rounded-lg bg-background text-body-md" />
            </div>

            <!-- Search by Location -->
            <div>
                <label class="block font-label-sm text-label-sm text-on-surface-variant mb-2 uppercase tracking-wider">Ubicación</label>
                <input type="text" 
                       name="location" 
                       placeholder="Ciudad, País..." 
                       value="@ViewBag.Location"
                       class="form-input w-full p-4 border border-outline-variant rounded-lg bg-background text-body-md" />
            </div>

            <!-- Available Date -->
            <div>
                <label class="block font-label-sm text-label-sm text-on-surface-variant mb-2 uppercase tracking-wider">Disponible desde</label>
                <input type="date" 
                       name="availableDate" 
                       value="@ViewBag.AvailableDate"
                       class="form-input w-full p-4 border border-outline-variant rounded-lg bg-background text-body-md" />
            </div>

            <!-- My Properties Filter (Owner only) -->
            @if (isOwner)
            {
                <div class="flex items-end">
                    <label class="flex items-center cursor-pointer">
                        <input type="checkbox" 
                               name="myPropertiesOnly" 
                               value="true" 
                               @(ViewBag.MyPropertiesOnly == true ? "checked" : "")
                               class="w-4 h-4 text-primary border-outline-variant rounded focus:ring-primary" />
                        <span class="ml-3 font-label-sm text-label-sm text-on-surface-variant uppercase tracking-wider">Solo mis propiedades</span>
                    </label>
                </div>
            }
        </div>

        <!-- Action Buttons -->
        <div class="flex gap-4">
            <button type="submit" class="primary-gold-btn px-8 py-3 font-label-md text-label-md uppercase tracking-widest rounded-lg">
                Buscar
            </button>
            <a asp-action="Index" class="px-8 py-3 font-label-md text-label-md uppercase tracking-widest rounded-lg border border-outline-variant text-on-surface hover:bg-surface-container transition-colors">
                Limpiar
            </a>
        </div>
    </form>
</div>

<!-- Create Property Button (Owner only) -->
@if (isOwner)
{
    <div class="mb-12">
        <a asp-action="Create" class="primary-gold-btn px-8 py-4 font-label-md text-label-md uppercase tracking-widest rounded-lg shadow-md inline-block">
            + Crear Nueva Propiedad
        </a>
    </div>
}

<!-- Properties Grid -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
    @foreach(var prop in Model)
    {
        <div class="bg-surface-container-lowest rounded-xl overflow-hidden border border-outline-variant hover:shadow-lg transition-shadow">
            <!-- Image -->
            <div class="relative h-64 bg-surface-container overflow-hidden">
                @if (!string.IsNullOrEmpty(prop.MainImageUrl))
                {
                    <img src="@prop.MainImageUrl" alt="@prop.Name" class="w-full h-full object-cover" />
                }
                else
                {
                    <div class="w-full h-full bg-gradient-to-br from-primary-container to-primary-fixed-dim flex items-center justify-center">
                        <span class="material-symbols-outlined text-[64px] text-on-primary-fixed opacity-30">home</span>
                    </div>
                }
                
                <!-- Availability Badge -->
                <div class="absolute top-4 right-4">
                    @if (prop.IsAvailable)
                    {
                        <span class="bg-secondary-fixed text-on-secondary-fixed font-label-md text-label-md px-4 py-2 rounded-lg uppercase tracking-wider">Disponible</span>
                    }
                    else
                    {
                        <span class="bg-error text-on-error font-label-md text-label-md px-4 py-2 rounded-lg uppercase tracking-wider">No Disponible</span>
                    }
                </div>

                <!-- Favorite Button -->
                <div class="absolute top-4 left-4">
                    @if (favoritePropertyIds.Contains(prop.Id))
                    {
                        <button class="w-10 h-10 bg-error text-on-error rounded-full flex items-center justify-center shadow-md">
                            ❤
                        </button>
                    }
                    else
                    {
                        <form asp-controller="Favorite" asp-action="Add" asp-route-propertyId="@prop.Id" method="post" style="display:inline;">
                            <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                            <button type="submit" class="w-10 h-10 bg-surface-container-lowest text-on-surface rounded-full flex items-center justify-center shadow-md hover:bg-error hover:text-on-error transition-colors">
                                ❤
                            </button>
                        </form>
                    }
                </div>
            </div>

            <!-- Content -->
            <div class="p-6 space-y-4">
                <!-- Title -->
                <h3 class="font-headline-md text-headline-md text-primary">@prop.Name</h3>

                <!-- Price -->
                <div class="text-secondary-fixed font-label-md text-label-md">
                    <span class="text-headline-lg font-bold">@prop.PricePerNight</span> / noche
                </div>

                <!-- Location -->
                <p class="font-body-sm text-body-sm text-on-surface-variant flex items-center gap-2">
                    <span class="material-symbols-outlined text-[18px]">location_on</span>
                    @prop.City, @prop.Country
                </p>

                <!-- Property Details Grid -->
                <div class="grid grid-cols-3 gap-4 border-t border-outline-variant pt-4">
                    <div class="text-center">
                        <div class="material-symbols-outlined text-[24px] text-on-surface-variant mx-auto mb-2">door_front</div>
                        <p class="font-label-sm text-label-sm text-on-surface-variant uppercase">@prop.Bedrooms Hab</p>
                    </div>
                    <div class="text-center">
                        <div class="material-symbols-outlined text-[24px] text-on-surface-variant mx-auto mb-2">bathroom</div>
                        <p class="font-label-sm text-label-sm text-on-surface-variant uppercase">@prop.Bathrooms Baños</p>
                    </div>
                    <div class="text-center">
                        <div class="material-symbols-outlined text-[24px] text-on-surface-variant mx-auto mb-2">group</div>
                        <p class="font-label-sm text-label-sm text-on-surface-variant uppercase">@prop.MaxGuests Huesp</p>
                    </div>
                </div>

                <!-- Actions -->
                <div class="flex gap-2 pt-4 border-t border-outline-variant">
                    <a asp-action="Details" asp-route-id="@prop.Id" class="flex-1 bg-primary text-on-primary font-label-md text-label-md py-3 rounded-lg text-center uppercase tracking-wider hover:bg-primary-container transition-colors">
                        Ver Detalles
                    </a>

                    @if (User.IsInRole("Guest") && prop.IsAvailable)
                    {
                        <a asp-controller="Booking" asp-action="Create" asp-route-propertyId="@prop.Id" class="flex-1 bg-secondary-fixed text-on-secondary-fixed font-label-md text-label-md py-3 rounded-lg text-center uppercase tracking-wider hover:bg-secondary-fixed-dim transition-colors">
                            Reservar
                        </a>
                    }

                    @if (isOwner && prop.OwnerId == user?.Id)
                    {
                        <a asp-action="Edit" asp-route-id="@prop.Id" class="flex-1 border border-outline text-on-surface font-label-md text-label-md py-3 rounded-lg text-center uppercase tracking-wider hover:bg-surface-container transition-colors">
                            Editar
                        </a>
                    }
                </div>

                <!-- Delete Button (Owner only) -->
                @if (isOwner && prop.OwnerId == user?.Id)
                {
                    <form asp-action="Delete" asp-route-id="@prop.Id" method="post">
                        <button type="submit" 
                                onclick="return confirm('¿Estás seguro de que deseas eliminar esta propiedad?');" 
                                class="w-full bg-error/10 text-error font-label-md text-label-md py-3 rounded-lg text-center uppercase tracking-wider hover:bg-error hover:text-on-error transition-colors">
                            Eliminar Propiedad
                        </button>
                    </form>
                }
            </div>
        </div>
    }
</div>