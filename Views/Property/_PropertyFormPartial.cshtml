@model main.ViewModels.Property.PropertyFormViewModel

<div style="margin-bottom: 10px;">
    <label asp-for="Name"></label><br />
    <input asp-for="Name" />
    <span asp-validation-for="Name" style="color:red;"></span>
</div>

<div style="margin-bottom: 10px;">
    <label asp-for="Description"></label><br />
    <textarea asp-for="Description"></textarea>
    <span asp-validation-for="Description" style="color:red;"></span>
</div>

<div style="margin-bottom: 10px;">
    <label asp-for="Address"></label><br />
    <input asp-for="Address" />
    <span asp-validation-for="Address" style="color:red;"></span>
</div>

<div style="margin-bottom: 10px;">
    <label asp-for="City"></label><br />
    <input asp-for="City" />
    <span asp-validation-for="City" style="color:red;"></span>
</div>

<div style="margin-bottom: 10px;">
    <label asp-for="Country"></label><br />
    <input asp-for="Country" />
    <span asp-validation-for="Country" style="color:red;"></span>
</div>

<div style="margin-bottom: 10px;">
    <label asp-for="MaxGuests"></label><br />
    <input asp-for="MaxGuests" type="number" />
    <span asp-validation-for="MaxGuests" style="color:red;"></span>
</div>

<div style="margin-bottom: 10px;">
    <label asp-for="PricePerNight">Price per Night ($)</label><br />
    <input asp-for="PricePerNight" type="number" step="0.01" />
    <span asp-validation-for="PricePerNight" style="color:red;"></span>
</div>

<div style="margin-bottom: 10px;">
    <label asp-for="Bedrooms"></label><br />
    <input asp-for="Bedrooms" type="number" />
    <span asp-validation-for="Bedrooms" style="color:red;"></span>
</div>

<div style="margin-bottom: 10px;">
    <label asp-for="Bathrooms"></label><br />
    <input asp-for="Bathrooms" type="number" />
    <span asp-validation-for="Bathrooms" style="color:red;"></span>
</div>

<div style="margin-bottom: 10px;">
    <label asp-for="MainImageUrl"></label><br />
    <input asp-for="MainImageUrl" />
    <span asp-validation-for="MainImageUrl" style="color:red;"></span>
</div>

<div style="margin-bottom: 10px;">
    <label>
        <input asp-for="IsAvailable" /> Is Available?
    </label>
</div>
