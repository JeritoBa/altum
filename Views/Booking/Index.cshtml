@model IEnumerable<main.Models.Booking>
@using Microsoft.AspNetCore.Identity
@using main.Models.Enums
@inject UserManager<main.Models.User> UserManager
@{
    ViewData["Title"] = "Reservas";
    var isOwner = User.IsInRole("Owner");
    var user = await UserManager.GetUserAsync(User);
}

<!-- Header Section -->
<div class="mb-12">
    <h1 class="font-headline-lg text-headline-lg text-primary mb-4">Mis Reservas</h1>
    <p class="font-body-lg text-body-lg text-on-surface-variant">Gestiona tus reservaciones y seguimiento de propiedades</p>
</div>

<!-- Filter Form -->
<div class="bg-surface-container-lowest rounded-xl border border-outline-variant p-8 mb-12">
    <form method="get" asp-action="Index" class="space-y-6">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
            <!-- Location Filter -->
            <div>
                <label class="block font-label-sm text-label-sm text-on-surface-variant mb-2 uppercase tracking-wider">Ubicación</label>
                <input type="text" 
                       name="location" 
                       placeholder="Ciudad, País..." 
                       value="@ViewBag.Location"
                       class="form-input w-full p-4 border border-outline-variant rounded-lg bg-background text-body-md" />
            </div>

            <!-- Date Filter -->
            <div>
                <label class="block font-label-sm text-label-sm text-on-surface-variant mb-2 uppercase tracking-wider">Fecha</label>
                <input type="date" 
                       name="date" 
                       value="@ViewBag.Date"
                       class="form-input w-full p-4 border border-outline-variant rounded-lg bg-background text-body-md" />
            </div>

            <!-- Property ID Filter (Owner only) -->
            @if (isOwner)
            {
                <div>
                    <label class="block font-label-sm text-label-sm text-on-surface-variant mb-2 uppercase tracking-wider">Propiedad</label>
                    <input type="number" 
                           name="propertyId" 
                           placeholder="ID..." 
                           value="@ViewBag.PropertyId"
                           class="form-input w-full p-4 border border-outline-variant rounded-lg bg-background text-body-md" />
                </div>
            }

            <!-- Active Only Filter (Owner only) -->
            @if (isOwner)
            {
                <div class="flex items-end">
                    <label class="flex items-center cursor-pointer">
                        <input type="checkbox" 
                               name="activesOnly" 
                               value="true" 
                               @(ViewBag.ActivesOnly == true ? "checked" : "")
                               class="w-4 h-4 text-primary border-outline-variant rounded focus:ring-primary" />
                        <span class="ml-3 font-label-sm text-label-sm text-on-surface-variant uppercase tracking-wider">Solo activas</span>
                    </label>
                </div>
            }
        </div>

        <!-- Action Buttons -->
        <div class="flex gap-4">
            <button type="submit" class="primary-gold-btn px-8 py-3 font-label-md text-label-md uppercase tracking-widest rounded-lg">
                Filtrar
            </button>
            <a asp-action="Index" class="px-8 py-3 font-label-md text-label-md uppercase tracking-widest rounded-lg border border-outline-variant text-on-surface hover:bg-surface-container transition-colors">
                Limpiar
            </a>
        </div>
    </form>
</div>

<!-- Bookings List -->
<div class="space-y-6">
    @if (!Model.Any())
    {
        <div class="bg-surface-container-lowest rounded-xl border border-outline-variant p-12 text-center">
            <span class="material-symbols-outlined text-[64px] text-on-surface-variant/30 block mb-4">calendar_month</span>
            <p class="font-body-lg text-body-lg text-on-surface-variant">No hay reservas disponibles</p>
        </div>
    }
    else
    {
        @foreach(var booking in Model)
        {
            <div class="bg-surface-container-lowest rounded-xl border border-outline-variant overflow-hidden hover:shadow-lg transition-shadow">
                <div class="p-8">
                    <!-- Header -->
                    <div class="flex items-start justify-between mb-6">
                        <div>
                            <h3 class="font-headline-md text-headline-md text-primary mb-2">@booking.Property.Name</h3>
                            <p class="font-body-sm text-body-sm text-on-surface-variant flex items-center gap-2">
                                <span class="material-symbols-outlined text-[18px]">location_on</span>
                                @booking.Property.City, @booking.Property.Country
                            </p>
                        </div>

                        <!-- Status Badge -->
                        <div>
                            @{
                                var statusColor = booking.State == BookingState.Completed ? "bg-secondary-fixed text-on-secondary-fixed" :
                                               booking.State == BookingState.Cancelled ? "bg-error text-on-error" :
                                               "bg-primary-fixed text-on-primary-fixed";
                            }
                            <span class="@statusColor font-label-md text-label-md px-4 py-2 rounded-lg uppercase tracking-wider">
                                @booking.State.ToString()
                            </span>
                        </div>
                    </div>

                    <!-- Details Grid -->
                    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-6 pb-6 border-b border-outline-variant">
                        <!-- Check-in -->
                        <div>
                            <p class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-wider mb-2">Check-in</p>
                            <p class="font-body-md text-body-md text-on-surface">@booking.CheckInDate.ToShortDateString()</p>
                        </div>

                        <!-- Check-out -->
                        <div>
                            <p class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-wider mb-2">Check-out</p>
                            <p class="font-body-md text-body-md text-on-surface">@booking.CheckOutDate.ToShortDateString()</p>
                        </div>

                        <!-- Guests -->
                        <div>
                            <p class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-wider mb-2">Huéspedes</p>
                            <p class="font-body-md text-body-md text-on-surface">@booking.GuestsCount</p>
                        </div>

                        <!-- Payment Status -->
                        <div>
                            <p class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-wider mb-2">Pago</p>
                            @if (booking.Paid)
                            {
                                <span class="text-secondary-fixed font-label-md">✓ Pagado</span>
                            }
                            else
                            {
                                <span class="text-error font-label-md">Pendiente</span>
                            }
                        </div>
                    </div>

                    <!-- Price -->
                    <div class="mb-6">
                        <p class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-wider mb-2">Precio Total</p>
                        <p class="text-secondary-fixed font-headline-md text-headline-md">
                            $@booking.TotalPrice
                        </p>
                    </div>

                    <!-- Actions -->
                    <div class="flex gap-4">
                        @if (((isOwner && booking.Property.OwnerId == user?.Id) || (!isOwner && booking.GuestId == user?.Id)) && 
                             booking.State != BookingState.Cancelled && booking.State != BookingState.Completed)
                        {
                            <form asp-action="CancelBooking" asp-route-id="@booking.Id" method="post">
                                <button type="submit" 
                                        onclick="return confirm('¿Estás seguro de que deseas cancelar esta reserva?');" 
                                        class="bg-error/10 text-error font-label-md text-label-md px-6 py-3 rounded-lg uppercase tracking-wider hover:bg-error hover:text-on-error transition-colors">
                                    Cancelar Reserva
                                </button>
                            </form>
                        }

                        @if (!isOwner && booking.State == BookingState.Pending && !booking.Paid)
                        {
                            <p class="font-body-sm text-body-sm text-on-surface-variant italic">
                                (Integración de pago próximamente)
                            </p>
                        }
                    </div>
                </div>
            </div>
        }
    }
</div>
