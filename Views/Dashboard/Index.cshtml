@model main.ViewModels.Dashboard.DashboardMetricsViewModel
@{
    ViewData["Title"] = "Owner Dashboard";
}

<h2>Owner Dashboard</h2>

@if (TempData["ErrorMessage"] != null)
{
    <div style="background-color: #f8d7da; color: #721c24; padding: 15px; margin-bottom: 20px; border: 1px solid #f5c6cb; border-radius: 4px;">
        @TempData["ErrorMessage"]
    </div>
}

<div style="background: #e9ecef; padding: 15px; border-radius: 8px; margin-bottom: 20px;">
    <h3 style="margin-top: 0;">Export Excel Report</h3>
    <form method="get" asp-action="ExportReport">
        <label>Property:</label>
        <select name="propertyId" style="padding: 5px;">
            <option value="">All Properties</option>
            @if (Model != null && Model.PropertyMetrics != null && Model.PropertyMetrics.Any())
            {
                foreach (var p in Model.PropertyMetrics)
                {
                    <option value="@p.PropertyId">@p.PropertyName</option>
                }
            }
        </select>

        <label style="margin-left: 10px;">Start Date:</label>
        <input type="date" name="startDate" />
        
        <label style="margin-left: 10px;">End Date:</label>
        <input type="date" name="endDate" />
        
        <button type="submit" style="margin-left: 10px; background-color: #28a745; color: white; border: none; padding: 6px 12px; border-radius: 4px; cursor: pointer; font-weight: bold;">Download Excel</button>
    </form>
</div>

<div style="background: #f9f9f9; padding: 15px; border-radius: 8px; margin-bottom: 20px;">
    <h3>Main Metrics</h3>

    <form method="get" asp-action="Index">
        <label>Start Date:</label>
        <input type="date" name="startDate" value="@(Model?.StartDate != DateTime.MinValue ? Model?.StartDate.ToString("yyyy-MM-dd") : "")" />
        
        <label style="margin-left: 10px;">End Date:</label>
        <input type="date" name="endDate" value="@(Model?.EndDate != DateTime.MinValue ? Model?.EndDate.ToString("yyyy-MM-dd") : "")" />
        
        <button type="submit" style="margin-left: 10px;">Filter</button>
        <a asp-action="Index" style="margin-left: 10px;">Current Month</a>
    </form>
</div>

@if (Model == null || Model.StartDate == DateTime.MinValue)
{
    <p>No data available.</p>
}
else
{
    <div style="display: flex; gap: 20px; margin-bottom: 30px;">
        <div style="flex: 1; background: #fff; border: 1px solid #ddd; padding: 20px; border-radius: 8px; text-align: center; box-shadow: 2px 2px 5px rgba(0,0,0,0.05);">
            <h3>Total Income</h3>
            <p style="font-size: 24px; color: #28a745; font-weight: bold;">$@Model.TotalIncome.ToString("N2")</p>
        </div>
        <div style="flex: 1; background: #fff; border: 1px solid #ddd; padding: 20px; border-radius: 8px; text-align: center; box-shadow: 2px 2px 5px rgba(0,0,0,0.05);">
            <h3>Occupancy Rate</h3>
            <p style="font-size: 24px; color: #007bff; font-weight: bold;">@Model.OccupancyRate.ToString("N2")%</p>
        </div>
        <div style="flex: 1; background: #fff; border: 1px solid #ddd; padding: 20px; border-radius: 8px; text-align: center; box-shadow: 2px 2px 5px rgba(0,0,0,0.05);">
            <h3>Total Bookings</h3>
            <p style="font-size: 24px; font-weight: bold;">@Model.TotalBookings</p>
        </div>
    </div>

    <h3>Metrics per Property</h3>
    <table style="width: 100%; border-collapse: collapse; margin-top: 15px;">
        <thead>
            <tr style="background: #f1f1f1;">
                <th style="padding: 10px; border: 1px solid #ddd; text-align: left;">Property Name</th>
                <th style="padding: 10px; border: 1px solid #ddd; text-align: right;">Income</th>
                <th style="padding: 10px; border: 1px solid #ddd; text-align: right;">Occupancy Rate</th>
                <th style="padding: 10px; border: 1px solid #ddd; text-align: center;">Bookings</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.PropertyMetrics.Any())
            {
                <tr>
                    <td colspan="4" style="padding: 10px; border: 1px solid #ddd; text-align: center;">No properties found.</td>
                </tr>
            }
            @foreach (var pm in Model.PropertyMetrics)
            {
                <tr>
                    <td style="padding: 10px; border: 1px solid #ddd;">@pm.PropertyName</td>
                    <td style="padding: 10px; border: 1px solid #ddd; text-align: right; color: #28a745; font-weight: bold;">$@pm.Income.ToString("N2")</td>
                    <td style="padding: 10px; border: 1px solid #ddd; text-align: right; color: #007bff;">@pm.OccupancyRate.ToString("N2")%</td>
                    <td style="padding: 10px; border: 1px solid #ddd; text-align: center;">@pm.BookingsCount</td>
                </tr>
            }
        </tbody>
    </table>
}
